<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ministorage.image_service.mapper.ImageVariantMapper">

    <resultMap id="variantResultMap" type="com.ministorage.image_service.domain.ImageVariant">
        <id     property="id"          column="id"/>
        <result property="imageId"     column="image_id"/>
        <result property="name"        column="name"/>
        <result property="objectKey"   column="object_key"/>
        <result property="width"       column="width"/>
        <result property="height"      column="height"/>
        <result property="size"        column="size"/>
        <result property="contentType" column="content_type"/>
        <result property="status"      column="status"/>
        <result property="createdAt"   column="created_at"/>
    </resultMap>

    <insert id="insert" parameterType="com.ministorage.image_service.domain.ImageVariant">
        INSERT INTO image_variants (id, image_id, name, object_key, width, height, size, content_type, status)
        VALUES (
                   #{id},
                   #{imageId},
                   #{name},
                   #{objectKey},
                   #{width},
                   #{height},
                   #{size},
                   #{contentType},
                   #{status}
               )
    </insert>

    <select id="findByImageId" resultMap="variantResultMap">
        SELECT id, image_id, name, object_key, width, height, size, content_type, status, created_at
        FROM image_variants
        WHERE image_id = #{imageId}
        ORDER BY name
    </select>

    <update id="updateStatus">
        UPDATE image_variants
        SET status = #{status}
        WHERE id = #{id}
    </update>

    <delete id="deleteByImageId">
        DELETE FROM image_variants WHERE image_id = #{imageId}
    </delete>

</mapper>