<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ministorage.image_service.mapper.ImageMapper">

    <resultMap id="imageResultMap" type="com.ministorage.image_service.domain.Image">
        <id     property="id"          column="id"/>
        <result property="objectKey"   column="object_key"/>
        <result property="bucket"      column="bucket"/>
        <result property="width"       column="width"/>
        <result property="height"      column="height"/>
        <result property="size"        column="size"/>
        <result property="contentType" column="content_type"/>
        <result property="acl"         column="acl"/>
        <result property="etag"        column="etag"/>
        <result property="createdAt"   column="created_at"/>
        <result property="updatedAt"   column="updated_at"/>
    </resultMap>

    <insert id="insert" parameterType="com.ministorage.image_service.domain.Image">
        INSERT INTO images (id, object_key, bucket, width, height, size, content_type, acl, etag)
        VALUES (
                   #{id},
                   #{objectKey},
                   #{bucket},
                   #{width},
                   #{height},
                   #{size},
                   #{contentType},
                   #{acl},
                   #{etag}
               )
    </insert>

    <select id="findById" resultMap="imageResultMap">
        SELECT id, object_key, bucket, width, height, size, content_type, acl, etag, created_at, updated_at
        FROM images
        WHERE id = #{id}
    </select>

    <select id="findByObjectKey" resultMap="imageResultMap">
        SELECT id, object_key, bucket, width, height, size, content_type, acl, etag, created_at, updated_at
        FROM images
        WHERE object_key = #{objectKey}
    </select>

    <select id="findAll" resultMap="imageResultMap">
        SELECT id, object_key, bucket, width, height, size, content_type, acl, etag, created_at, updated_at
        FROM images
        <if test="cursor != null and cursor != ''">
            WHERE id &lt; #{cursor}
        </if>
        ORDER BY created_at DESC
        LIMIT #{limit}
    </select>

    <select id="count" resultType="long">
        SELECT COUNT(*) FROM images
    </select>

    <delete id="deleteById">
        DELETE FROM images WHERE id = #{id}
    </delete>

</mapper>