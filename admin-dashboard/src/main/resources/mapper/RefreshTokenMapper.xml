<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ministorage.admin_dashboard.mapper.RefreshTokenMapper">

    <resultMap id="refreshTokenResultMap" type="com.ministorage.admin_dashboard.domain.RefreshToken">
        <id     property="id"         column="id"/>
        <result property="adminId"    column="admin_id"/>
        <result property="tokenHash"  column="token_hash"/>
        <result property="expiresAt"  column="expires_at"/>
        <result property="createdAt"  column="created_at"/>
    </resultMap>

    <insert id="insert" parameterType="com.ministorage.admin_dashboard.domain.RefreshToken">
        INSERT INTO refresh_tokens (id, admin_id, token_hash, expires_at)
        VALUES (#{id}, #{adminId}, #{tokenHash}, #{expiresAt})
    </insert>

    <select id="findByTokenHash" resultMap="refreshTokenResultMap">
        SELECT id, admin_id, token_hash, expires_at, created_at
        FROM refresh_tokens
        WHERE token_hash = #{tokenHash}
    </select>

    <delete id="deleteByTokenHash">
        DELETE FROM refresh_tokens WHERE token_hash = #{tokenHash}
    </delete>

    <delete id="deleteByAdminId">
        DELETE FROM refresh_tokens WHERE admin_id = #{adminId}
    </delete>

    <delete id="deleteExpired">
        DELETE FROM refresh_tokens WHERE expires_at &lt; now()
    </delete>

</mapper>