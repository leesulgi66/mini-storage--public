<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ministorage.admin_dashboard.mapper.AdminUserMapper">

    <resultMap id="adminUserResultMap" type="com.ministorage.admin_dashboard.domain.AdminUser">
        <id     property="id"           column="id"/>
        <result property="email"        column="email"/>
        <result property="passwordHash" column="password_hash"/>
        <result property="role"         column="role"/>
        <result property="createdAt"    column="created_at"/>
    </resultMap>

    <select id="findByEmail" resultMap="adminUserResultMap">
        SELECT id, email, password_hash, role, created_at
        FROM admin_users
        WHERE email = #{email}
    </select>

    <select id="findById" resultMap="adminUserResultMap">
        SELECT id, email, password_hash, role, created_at
        FROM admin_users
        WHERE id = #{id}
    </select>

</mapper>